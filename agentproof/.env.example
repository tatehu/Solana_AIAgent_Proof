# 见证节点集群环境变量（docker-compose 用）
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
AGENTPROOF_PROGRAM_ID=AgPr111111111111111111111111111111111111111

# 三个见证节点各自独立的私钥（base58）
WITNESS_1_PRIVATE_KEY=YOUR_WITNESS_1_PRIVATE_KEY_BASE58
WITNESS_2_PRIVATE_KEY=YOUR_WITNESS_2_PRIVATE_KEY_BASE58
WITNESS_3_PRIVATE_KEY=YOUR_WITNESS_3_PRIVATE_KEY_BASE58

# 风控服务私钥
RISK_MONITOR_PRIVATE_KEY=YOUR_RISK_MONITOR_PRIVATE_KEY_BASE58
